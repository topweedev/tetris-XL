{
  "compilerOptions": {
    // Target modern browsers baseline per ADR-0006 §4 (Chrome 80+ / FF 113+ / Safari 16.4+)
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,

    // Emit is delegated to Vite; tsc is used for type-check only (`pnpm typecheck`)
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Strictness (per user-selected defaults for spike-prep)
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    // Interop
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,

    // Path root
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@build/*": ["src/build/*"]
    },

    // Vite build-time env constants (see vite.config.ts define block)
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.js",
    "scripts/**/*.mjs",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
